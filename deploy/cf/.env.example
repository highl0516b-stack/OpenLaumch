# ============================================================
# OpenLaunch Cloudflare 環境變數配置
# 複製為 .env 並填入實際值 → cp .env.example .env
# ⚠️ .env.example 絕不含真實密鑰
# ============================================================

# --- Cloudflare 帳戶 ---
CF_ACCOUNT_ID=your_account_id_here
CF_API_TOKEN=your_cf_access_token_here

# --- OpenRouter（中繼AI，HK IP被封） ---
OPENROUTER_API_KEY=your_openrouter_key_here

# --- GitHub ---
GITHUB_TOKEN=your_github_token_here
GITHUB_PAT=your_github_pat_here
GITHUB_OWNER=highl0516b-stack
GITHUB_REPO=OpenLaumch

# --- 整合服務 ---
NOTION_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_notion_db_id_here
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_CHANNEL_ID=your_slack_channel_id
CRM_BASE_URL=https://api.hubspot.com
CRM_API_KEY=your_crm_api_key
HUBSPOT_PRIVATE_APP_TOKEN=your_hubspot_token

# --- KIKO ---
KIKO_BYOK=your_kiko_byok_here

# --- AI ---
OPENAI_API_KEY=your_openai_key_if_needed
OPENAI_MODEL=gpt-4.1-mini

# --- Wrangler 部署配置 ---
WRANGLER_CLOUDFLARE_ACCOUNT_ID=your_account_id_here
WRANGLER_CLOUDFLARE_API_AUTH_DOMAIN=openlaunch.example.com
WRANGLER_CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4

# --- 環境 ---
NODE_ENV=production
ENVIRONMENT=production
