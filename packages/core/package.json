{
  "name": "@openlaunch/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./mcp/types": {
      "types": "./dist/mcp/types.d.ts",
      "import": "./dist/mcp/types.js"
    },
    "./mcp/gateway": {
      "types": "./dist/mcp/gateway.d.ts",
      "import": "./dist/mcp/gateway.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.3"
  }
}