NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
OPENLAUNCH_API_URL=http://localhost:4000
OPENLAUNCH_MCP_MODE=sandbox
OPENLAUNCH_TENANT_ID=local
OPENLAUNCH_AI_PROVIDER=local
OPENLAUNCH_ALLOWED_PATHS=/path/to/repo
OPENLAUNCH_FILE_ROOT=/path/to/repo

# API server
PORT=4000
API_PORT=4000
HOSTNAME=0.0.0.0
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_CALLS=60
API_MAX_BODY_BYTES=1000000

# Cloudflare
CF_ACCESS_TOKEN=...
CF_ACCESS_ID=...
CF_API_KEY=...
CLOUDFLARE_ACCESS_TOKEN=...
CLOUDFLARE_ACCESS_ID=...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...

# GitHub
GITHUB_TOKEN=...
GITHUB_FINE_GRAINED_TOKEN=...
GITHUB_CLASSIC_TOKEN=...
GITHUB_OWNER=...
GITHUB_REPO=...